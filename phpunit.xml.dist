<?xml version="1.0"?>
<phpunit bootstrap="vendor/silverstripe/framework/tests/bootstrap.php" colors="true" cacheDirectory=".phpunit.cache">
  <testsuite name="nswdpc/silverstripe-userforms-ipcollection">
    <directory>tests/</directory>
  </testsuite>
  <source>
    <include>
      <directory suffix=".php">src/</directory>
    </include>
    <exclude>
      <directory suffix=".php">tests/</directory>
    </exclude>
  </source>
</phpunit>
